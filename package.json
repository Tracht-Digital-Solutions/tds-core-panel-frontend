{
  "name": "@tracht-digital-solutions/tds-core-panel-frontend",
  "version": "0.11.2",
  "description": "Base panel host for the TDS panel platform. Ships the shell (Layout, auth gate), base pages (dashboard, login, users, settings, wiki) + the corePanelBase Astro integration. Consumed by the product repos (tds-admin-panel / tds-customer-panel), each of which composes it with its own extension set + deploy pipeline.",
  "license": "UNLICENSED",
  "private": false,
  "type": "module",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "exports": {
    "./astro": {
      "types": "./dist/astro.d.ts",
      "import": "./dist/astro.js",
      "require": "./dist/astro.cjs"
    },
    "./src/*": "./src/*"
  },
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@fontsource/lato": "^5.2.7",
    "@tracht-digital-solutions/tds-panel-contract": "^1.0.0",
    "@tracht-digital-solutions/tds-shared": "^0.12.0"
  },
  "peerDependencies": {
    "@astrojs/react": ">=5",
    "@tailwindcss/postcss": ">=4",
    "astro": ">=6",
    "react": ">=18",
    "react-dom": ">=18",
    "tailwindcss": ">=4"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "astro": "^6.4.2",
    "rimraf": "^6.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tracht-Digital-Solutions/tds-core-frontend-pkg.git"
  }
}
