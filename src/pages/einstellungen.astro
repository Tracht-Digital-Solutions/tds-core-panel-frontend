---
// Einstellungen — the settings HOST. Renders every settings section contributed
// by the enabled extensions (via virtual:panel-settings), the same way the
// Dashboard hosts widgets. Base-service settings (once ported) render above.
import Layout from "../layouts/Layout.astro";
import { settings } from "virtual:panel-settings";
---

<Layout title="Einstellungen">
  <h1 class="text-xl font-bold mb-4">Einstellungen</h1>
  {settings.length === 0 ? <p>Keine Einstellungen verfügbar.</p> : null}
  <div class="settings-list flex flex-col gap-6">
    {
      settings.map((panel) => {
        const Panel = panel.Component as any;
        return (
          <section class="card p-4" data-settings={panel.id}>
            <h2 class="text-lg font-semibold mb-2">{panel.label}</h2>
            <Panel />
          </section>
        );
      })
    }
  </div>
</Layout>
