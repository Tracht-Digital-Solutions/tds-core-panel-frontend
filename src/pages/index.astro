---
// Dashboard — the widget HOST. Renders every widget contributed by the enabled
// extensions (via virtual:panel-widgets). The full port adds per-user layout +
// permission gating; the smoke renders them all to prove server render +
// island hydration flow through the contract's widget slot.
import Layout from "../layouts/Layout.astro";
import { widgets } from "virtual:panel-widgets";
---

<Layout title="Dashboard">
  <h1>Dashboard</h1>
  <div class="dashboard-grid">
    {
      widgets.map((widget) => {
        const Widget = widget.Component as any;
        return (
          <section class="widget-slot" data-widget={widget.id} data-size={widget.size}>
            <Widget />
          </section>
        );
      })
    }
  </div>
</Layout>
